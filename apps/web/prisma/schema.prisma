generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Sex {
  M
  F
}

enum DogLifecycleState {
  ALIVE
  DECEASED
  TRANSFERRED
  RETIRED
}

enum DogVisibilityState {
  VISIBLE
  HIDDEN_NEONATAL_LOSS
}

enum DogMarketState {
  NOT_FOR_SALE
  LISTED_PLAYER
  LISTED_NPC
  SOLD_PENDING_TRANSFER
}

enum DogOriginType {
  FOUNDATION
  PLAYER_BRED
  NPC_BRED
  IMPORTED
}

enum BreedingAttemptStatus {
  INITIATED
  CHECKED_NOT_PREGNANT
  PREGNANT
  WHELPED
  FAILED
  CANCELLED
}

enum ShowClusterStatus {
  SCHEDULED
  OPEN
  CLOSED
  COMPLETE
  CANCELLED
}

enum ShowDayStatus {
  SCHEDULED
  ENTRY_OPEN
  ENTRY_LOCKED
  JUDGING
  RESULTS_PUBLISHED
  CANCELLED
}

enum ShowJudgingBlockStatus {
  SCHEDULED
  ENTRY_OPEN
  ENTRY_LOCKED
  JUDGING
  RESULTS_PUBLISHED
  CANCELLED
}

enum ShowEntryStatus {
  ENTERED
  WITHDRAWN
  INELIGIBLE
  ABSENT
  JUDGED
}

enum SellerType {
  PLAYER
  NPC
  SYSTEM
}

enum DogListingStatus {
  ACTIVE
  EXPIRED
  SOLD
  CANCELLED
}

enum BulletinThreadSource {
  PLAYER
  SYSTEM
}

enum BulletinThreadStatus {
  OPEN
  LOCKED
  HIDDEN
}

enum LedgerTransactionType {
  STARTER_FUNDS
  SHOW_ENTRY_FEE
  TRAVEL_COST
  HANDLER_FEE
  BREEDING_FEE
  DOG_PURCHASE
  DOG_SALE
  PUPPY_REHOME
  STUD_FEE_IN
  STUD_FEE_OUT
  KENNEL_SERVICE_PAYOUT
  LISTING_FEE
  UPKEEP
  PRIZE_WINNINGS
  HEALTH_TEST_FEE
  REFUND
  GROOMING_INCOME
  STEWARDING_INCOME
}

enum KennelNoticeType {
  BULLETIN_REPLY
  NEW_CHAMPION
  DOG_DEATH
  LITTER_BORN
  DID_NOT_TAKE
  STUD_FEE_RECEIVED
  DOG_SOLD
  INVITATIONAL_INVITE
  KENNEL_SERVICE
}

enum KennelServiceType {
  CLUB_STEWARDING
  GROOMING_ASSISTANCE
  BOARDING
  PUPPY_SOCIALIZATION
  TRANSPORT_ASSISTANCE
  HANDLING_ASSISTANCE
}

enum KennelServiceClaimStatus {
  CLAIMED
  COMPLETED
  CANCELLED
}

enum GroomingListingStatus {
  OPEN
  COMPLETED
  CANCELLED
}

enum GroomingServiceActionType {
  SELF_GROOM
  OUTSIDE_GROOM
}

enum DogConditionEventType {
  GROOMING_GAIN
  MISSED_GROOMING_DECAY
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  displayName  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  kennel              Kennel?
  passwordResetTokens PasswordResetToken[]
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Kennel {
  id              String   @id @default(cuid())
  userId          String?  @unique
  name            String   @unique
  slug            String   @unique
  isNpc           Boolean  @default(false)
  homeDistrict    Int?
  balance         Int      @default(0)
  reputationScore Int      @default(0)
  publicSlogan    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id])

  ownedDogs               Dog[]               @relation("OwnerKennelDogs")
  bredDogs                Dog[]               @relation("BreederKennelDogs")
  createdBreedingAttempts BreedingAttempt[]   @relation("BreedingCreatedByKennel")
  bredLitters             Litter[]            @relation("LitterBredByKennel")
  showEntries             ShowEntry[]
  ledgerTransactions      LedgerTransaction[] @relation("PrimaryKennelLedger")
  counterpartyLedger      LedgerTransaction[] @relation("CounterpartyKennelLedger")
  dogListings             DogListing[]        @relation("SellerKennelListings")
  purchasedListings       DogListing[]        @relation("BuyerKennelListings")
  showWeekendPlans        KennelShowWeekendPlan[]
  bulletinThreads         BulletinThread[]
    bulletinPosts           BulletinPost[]
    notices                 KennelNotice[]
    privateDogNotes         KennelDogPrivateNote[]
    areas                   KennelArea[]
    serviceClaims           KennelServiceClaim[]
    groomingListingsOwned   GroomingListing[] @relation("GroomingListingOwnerKennel")
    groomingListingsClaimed GroomingListing[] @relation("GroomingListingGroomerKennel")
    groomingActionsOwned    GroomingServiceAction[] @relation("GroomingActionOwnerKennel")
    groomingActionsPerformed GroomingServiceAction[] @relation("GroomingActionGroomerKennel")
    conditionEventsActed    DogConditionEvent[] @relation("DogConditionEventActorKennel")
    conditionEventsOwned    DogConditionEvent[] @relation("DogConditionEventOwnerKennel")
    serviceProfile          KennelServiceProfile?

  @@index([userId])
  @@index([homeDistrict])
}

model Breed {
  code2          String   @id
  name           String   @unique
  groupName      String?
  isActive       Boolean  @default(false)
  releaseVersion Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  dogs        Dog[]
  litters     Litter[]
  showEntries ShowEntry[]
  showResults ShowResult[]
  showAwards  ShowAward[]
  showJudgingBlocks ShowJudgingBlock[]

  @@index([releaseVersion])
}

model Dog {
  id                 String            @id @default(cuid())
  regNumber          String            @unique
  callName           String?
  registeredName     String?
  breedCode2         String
  ownerKennelId      String?
  breederKennelId    String?
  sireId             String?
  damId              String?
  litterId           String?
  litterOrder        Int?
  sex                Sex
  birthEpoch         Int
  deathEpoch         Int?
  lifecycleState     DogLifecycleState @default(ALIVE)
  visibilityState    DogVisibilityState @default(VISIBLE)
  isPlayerVisible    Boolean           @default(true)
  showInMemoriam     Boolean           @default(true)
  marketState        DogMarketState    @default(NOT_FOR_SALE)
  originType         DogOriginType
  isFoundation       Boolean           @default(false)
  coiPercent         Float?
  coiGenerationDepth Int?

  visibleTitlePrefix String?
  visibleTitleSuffix String?
  notesPublic        String?

  // Hidden inherited traits
  traitHead         Int
  traitForequarters Int
  traitHindquarters Int
  traitGait         Int
  traitCoat         Int
  traitSize         Int
  traitTemperament  Int
  traitShowShine    Int
  traitFeet         Int
  traitTopline      Int

  // Current mutable dog state
  ringObedience Int @default(0)
  muscleTone    Int @default(0)
  coatCondition Float @default(0)
  fatiguePoints Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  breed         Breed   @relation(fields: [breedCode2], references: [code2])
  ownerKennel   Kennel? @relation("OwnerKennelDogs", fields: [ownerKennelId], references: [id])
  breederKennel Kennel? @relation("BreederKennelDogs", fields: [breederKennelId], references: [id])

  sire   Dog?  @relation("DogSire", fields: [sireId], references: [id])
  sireOf Dog[] @relation("DogSire")

  dam   Dog?  @relation("DogDam", fields: [damId], references: [id])
  damOf Dog[] @relation("DogDam")

  litter Litter? @relation(fields: [litterId], references: [id])

  breedingAttemptsAsSire BreedingAttempt[] @relation("BreedingSire")
  breedingAttemptsAsDam  BreedingAttempt[] @relation("BreedingDam")

  siredLitters  Litter[] @relation("LitterSire")
  dammedLitters Litter[] @relation("LitterDam")

  showEntries        ShowEntry[]
  showResults        ShowResult[]
  showAwards         ShowAward[]
  showPrestigeCredits DogShowPrestigeCredit[]
  yearlyPrestigeStats DogYearlyPrestigeStat[]
  ledgerTransactions LedgerTransaction[]
  listings           DogListing[]
  titleProgress      DogTitleProgress?
    healthTests        HealthTestRecord[]
    healthConditionTruths DogHealthConditionTruth[]
    infectiousDiseaseStatuses DogInfectiousDiseaseStatus[] @relation("DogDiseaseStatuses")
    infectiousDiseaseSourceFor DogInfectiousDiseaseStatus[] @relation("DogDiseaseSource")
    infectiousDiseaseTests InfectiousDiseaseTestRecord[]
    privateKennelNotes KennelDogPrivateNote[]
    kennelAreaMemberships KennelAreaDog[]
    serviceClaims KennelServiceClaim[]
    groomingListings GroomingListing[]
    groomingServiceActions GroomingServiceAction[]
    conditionEvents DogConditionEvent[]

  @@index([breedCode2])
  @@index([ownerKennelId])
  @@index([breederKennelId])
  @@index([sireId])
  @@index([damId])
  @@index([litterId])
  @@index([lifecycleState])
  @@index([visibilityState])
  @@index([isPlayerVisible])
  @@index([marketState])
}

  model KennelDogPrivateNote {
  id        String   @id @default(cuid())
  kennelId  String
  dogId     String
  notes     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  kennel Kennel @relation(fields: [kennelId], references: [id], onDelete: Cascade)
  dog    Dog    @relation(fields: [dogId], references: [id], onDelete: Cascade)

  @@unique([kennelId, dogId])
    @@index([dogId])
  }

  model KennelArea {
    id        String   @id @default(cuid())
    kennelId  String
    name      String
    sortOrder Int      @default(0)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    kennel Kennel          @relation(fields: [kennelId], references: [id], onDelete: Cascade)
    dogs   KennelAreaDog[]

    @@unique([kennelId, name])
    @@index([kennelId, sortOrder])
  }

  model KennelAreaDog {
    id           String   @id @default(cuid())
    kennelAreaId String
    dogId        String
    addedAt      DateTime @default(now())

    area KennelArea @relation(fields: [kennelAreaId], references: [id], onDelete: Cascade)
    dog  Dog        @relation(fields: [dogId], references: [id], onDelete: Cascade)

    @@unique([kennelAreaId, dogId])
    @@index([dogId])
  }

model Judge {
  id           String  @id
  judgeCode    String  @unique
  name         String
  style        String?
  isActive     Boolean @default(true)
  homeDistrict Int?

  weightTypeExpression          Float
  weightStructureBalance        Float
  weightMovement                Float
  weightCoatPresentation        Float
  weightTemperamentRingBehavior Float
  weightConditioningHandling    Float

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  showDays    ShowDay[]
  showResults ShowResult[]
  showAwards  ShowAward[]
  showJudgingBlocks ShowJudgingBlock[]

  @@index([isActive])
  @@index([homeDistrict])
}

model BreedingAttempt {
  id                String                @id @default(cuid())
  sireId            String
  damId             String
  breedCode2        String
  createdEpoch      Int
  pregCheckEpoch    Int?
  dueEpoch          Int?
  checkedEpoch      Int?
  isPregnant        Boolean?
  whelpedEpoch      Int?
  status            BreedingAttemptStatus @default(INITIATED)
  litterId          String?               @unique
  rngSeed           Int?
  createdByKennelId String?
  studFeeAmount     Int?
  notes             String?

  sire            Dog     @relation("BreedingSire", fields: [sireId], references: [id])
  dam             Dog     @relation("BreedingDam", fields: [damId], references: [id])
  createdByKennel Kennel? @relation("BreedingCreatedByKennel", fields: [createdByKennelId], references: [id])
  litter          Litter? @relation("BreedingAttemptLitter", fields: [litterId], references: [id])
  infectiousDiseaseTests InfectiousDiseaseTestRecord[]

  @@index([sireId])
  @@index([damId])
  @@index([breedCode2])
  @@index([createdByKennelId])
  @@index([status])
}

model Litter {
  id             String   @id @default(cuid())
  breedCode2     String
  serial7        String
  bornEpoch      Int
  sireId         String
  damId          String
  pupCount       Int
  bredByKennelId String?
  createdAt      DateTime @default(now())

  breed           Breed            @relation(fields: [breedCode2], references: [code2])
  sire            Dog              @relation("LitterSire", fields: [sireId], references: [id])
  dam             Dog              @relation("LitterDam", fields: [damId], references: [id])
  bredByKennel    Kennel?          @relation("LitterBredByKennel", fields: [bredByKennelId], references: [id])
  breedingAttempt BreedingAttempt? @relation("BreedingAttemptLitter")

  puppies Dog[]

  @@unique([breedCode2, serial7])
  @@index([sireId])
  @@index([damId])
  @@index([bredByKennelId])
}

model ShowCluster {
  id              String            @id @default(cuid())
  name            String
  year            Int
  district        Int
  startEpoch      Int
  endEpoch        Int
  entryOpenEpoch  Int
  entryCloseEpoch Int
  status          ShowClusterStatus @default(SCHEDULED)
  createdAt       DateTime          @default(now())

  showDays           ShowDay[]
  ledgerTransactions LedgerTransaction[]
  primaryWeekendPlans KennelShowWeekendPlan[] @relation("PrimaryShowWeekendCluster")
  serviceClaims      KennelServiceClaim[]

  @@index([district])
  @@index([year])
  @@index([status])
}

model KennelShowWeekendPlan {
  id               String   @id @default(cuid())
  kennelId         String
  weekendKey       String
  primaryClusterId String
  travelFeeCharged Int      @default(0)
  createdAtEpoch   Int
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  kennel         Kennel      @relation(fields: [kennelId], references: [id])
  primaryCluster ShowCluster @relation("PrimaryShowWeekendCluster", fields: [primaryClusterId], references: [id])

  @@unique([kennelId, weekendKey])
  @@index([primaryClusterId])
  @@index([weekendKey])
}

model ShowDay {
  id                        String        @id @default(cuid())
  clusterId                 String
  scheduledEpoch            Int
  dayIndex                  Int
  judgeId                   String
  status                    ShowDayStatus @default(SCHEDULED)
  publishedAtEpoch          Int?
  prestigeCalculatedAtEpoch Int?
  createdAt                 DateTime      @default(now())

  cluster ShowCluster @relation(fields: [clusterId], references: [id])
  judge   Judge       @relation(fields: [judgeId], references: [id])

  showEntries ShowEntry[]
  showResults ShowResult[]
  showAwards  ShowAward[]
  prestigeCredits DogShowPrestigeCredit[]
  judgingBlocks ShowJudgingBlock[]

  @@unique([clusterId, dayIndex])
  @@index([judgeId])
  @@index([scheduledEpoch])
  @@index([status])
}

model ShowJudgingBlock {
  id               String                  @id @default(cuid())
  showDayId        String
  judgeId          String
  breedCode2       String
  ringNumber       Int
  ringName         String?
  startEpoch       Int
  classType        String                  @default("REGULAR")
  blockOrder       Int
  entryCountHint   Int?
  status           ShowJudgingBlockStatus  @default(SCHEDULED)
  publishedAtEpoch Int?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  showDay ShowDay @relation(fields: [showDayId], references: [id])
  judge   Judge   @relation(fields: [judgeId], references: [id])
  breed   Breed   @relation(fields: [breedCode2], references: [code2])

  showEntries ShowEntry[]
  showResults ShowResult[]
  showAwards  ShowAward[]

  @@unique([showDayId, ringNumber, blockOrder])
  @@index([showDayId])
  @@index([judgeId])
  @@index([breedCode2])
  @@index([startEpoch])
  @@index([status])
}

model ShowEntry {
  id                   String          @id @default(cuid())
  showDayId            String
  judgingBlockId       String?
  dogId                String
  kennelId             String
  enteredKennelId      String?
  enteredKennelName    String?
  enteredKennelSlug    String?
  breedCode2           String
  entryStatus          ShowEntryStatus @default(ENTERED)
  enteredAtEpoch       Int
  feeCharged           Int
  handlerUsed          Boolean         @default(false)
  conditioningSnapshot Int?
  fatigueSnapshot      Int?

  showDay ShowDay @relation(fields: [showDayId], references: [id])
  judgingBlock ShowJudgingBlock? @relation(fields: [judgingBlockId], references: [id])
  dog     Dog     @relation(fields: [dogId], references: [id])
  kennel  Kennel  @relation(fields: [kennelId], references: [id])
  breed   Breed   @relation(fields: [breedCode2], references: [code2])

  showResult         ShowResult?
  showAwards         ShowAward[]
  ledgerTransactions LedgerTransaction[]

  @@unique([showDayId, dogId])
  @@index([judgingBlockId])
  @@index([dogId])
  @@index([kennelId])
  @@index([enteredKennelId])
  @@index([breedCode2])
  @@index([entryStatus])
}

model ShowResult {
  id                         String   @id @default(cuid())
  showEntryId                String   @unique
  showDayId                  String
  judgingBlockId             String?
  dogId                      String
  enteredKennelId            String?
  enteredKennelName          String?
  enteredKennelSlug          String?
  breedCode2                 String
  judgeId                    String
  finalRank                  Int?
  placementCode              String?
  baseScore                  Float
  finalScore                 Float
  dqCode                     String?
  pointsAwarded              Int      @default(0)
  isMajor                    Boolean  @default(false)
  uniqueKennelsInCompetition Int?
  publishedAtEpoch           Int
  scoringVersion             String
  createdAt                  DateTime @default(now())

  showEntry ShowEntry @relation(fields: [showEntryId], references: [id])
  showDay   ShowDay   @relation(fields: [showDayId], references: [id])
  judgingBlock ShowJudgingBlock? @relation(fields: [judgingBlockId], references: [id])
  dog       Dog       @relation(fields: [dogId], references: [id])
  breed     Breed     @relation(fields: [breedCode2], references: [code2])
  judge     Judge     @relation(fields: [judgeId], references: [id])
  showAwards ShowAward[]

  @@index([showDayId])
  @@index([judgingBlockId])
  @@index([dogId])
  @@index([enteredKennelId])
  @@index([breedCode2])
  @@index([judgeId])
  @@index([pointsAwarded])
}

model ShowAward {
  id                         String   @id @default(cuid())
  showResultId               String?
  showEntryId                String
  showDayId                  String
  judgingBlockId             String?
  dogId                      String
  breedCode2                 String
  judgeId                    String
  awardCode                  String
  awardGroup                 String
  sex                        Sex?
  rank                       Int?
  pointsAwarded              Int      @default(0)
  isMajor                    Boolean  @default(false)
  dogsInCompetition          Int?
  uniqueKennelsInCompetition Int?
  publishedAtEpoch           Int
  createdAt                  DateTime @default(now())

  showResult ShowResult? @relation(fields: [showResultId], references: [id])
  showEntry  ShowEntry   @relation(fields: [showEntryId], references: [id])
  showDay    ShowDay     @relation(fields: [showDayId], references: [id])
  judgingBlock ShowJudgingBlock? @relation(fields: [judgingBlockId], references: [id])
  dog        Dog         @relation(fields: [dogId], references: [id])
  breed      Breed       @relation(fields: [breedCode2], references: [code2])
  judge      Judge       @relation(fields: [judgeId], references: [id])

  @@index([showResultId])
  @@index([showEntryId])
  @@index([showDayId])
  @@index([judgingBlockId])
  @@index([dogId])
  @@index([breedCode2])
  @@index([judgeId])
  @@index([awardCode])
  @@index([pointsAwarded])
}

model DogShowPrestigeCredit {
  id                  String   @id @default(cuid())
  dogId               String
  showDayId           String
  gameYear            Int
  breedCode2          String
  breedDogsBeaten     Int      @default(0)
  allBreedDogsBeaten  Int      @default(0)
  breedWinCount       Int      @default(0)
  groupWinCount       Int      @default(0)
  bestInShowWinCount  Int      @default(0)
  reserveBisCount     Int      @default(0)
  calculatedAtEpoch   Int
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  dog     Dog     @relation(fields: [dogId], references: [id])
  showDay ShowDay @relation(fields: [showDayId], references: [id])

  @@unique([dogId, showDayId])
  @@index([showDayId])
  @@index([gameYear])
  @@index([breedCode2])
  @@index([breedDogsBeaten])
  @@index([allBreedDogsBeaten])
}

model DogYearlyPrestigeStat {
  id                  String   @id @default(cuid())
  dogId               String
  gameYear            Int
  breedCode2          String
  breedDogsBeaten     Int      @default(0)
  allBreedDogsBeaten  Int      @default(0)
  breedWinCount       Int      @default(0)
  groupWinCount       Int      @default(0)
  bestInShowWinCount  Int      @default(0)
  reserveBisCount     Int      @default(0)
  updatedAtEpoch      Int
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  dog Dog @relation(fields: [dogId], references: [id])

  @@unique([dogId, gameYear])
  @@index([gameYear])
  @@index([breedCode2])
  @@index([breedDogsBeaten])
  @@index([allBreedDogsBeaten])
}

model LedgerTransaction {
  id                   String                @id @default(cuid())
  kennelId             String
  transactionType      LedgerTransactionType
  amount               Int
  balanceAfter         Int?
  occurredAtEpoch      Int
  dogId                String?
  litterId             String?
  showClusterId        String?
  showEntryId          String?
  counterpartyKennelId String?
  memo                 String?
  metadataJson         Json?
  createdAt            DateTime              @default(now())

  kennel             Kennel       @relation("PrimaryKennelLedger", fields: [kennelId], references: [id])
  dog                Dog?         @relation(fields: [dogId], references: [id])
  showCluster        ShowCluster? @relation(fields: [showClusterId], references: [id])
  showEntry          ShowEntry?   @relation(fields: [showEntryId], references: [id])
  counterpartyKennel Kennel?      @relation("CounterpartyKennelLedger", fields: [counterpartyKennelId], references: [id])

  @@index([kennelId])
  @@index([dogId])
  @@index([showClusterId])
  @@index([showEntryId])
  @@index([counterpartyKennelId])
  @@index([occurredAtEpoch])
  @@index([transactionType])
}

model KennelServiceClaim {
  id               String                   @id @default(cuid())
  kennelId         String
  serviceType      KennelServiceType
  showClusterId    String?
  dogId            String?
  weekendKey       String?
  status           KennelServiceClaimStatus @default(CLAIMED)
  payoutAmount     Int
  claimedAtEpoch   Int
  completedAtEpoch Int?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt

  kennel      Kennel       @relation(fields: [kennelId], references: [id])
  showCluster ShowCluster? @relation(fields: [showClusterId], references: [id])
  dog         Dog?         @relation(fields: [dogId], references: [id])

  @@unique([kennelId, serviceType, showClusterId])
  @@unique([kennelId, serviceType, weekendKey])
  @@index([kennelId])
  @@index([serviceType])
  @@index([showClusterId])
  @@index([dogId])
  @@index([weekendKey])
  @@index([status])
}

model GroomingListing {
  id               String                @id @default(cuid())
  dogId            String
  ownerKennelId    String
  status           GroomingListingStatus @default(OPEN)
  price            Int
  listedAtEpoch    Int
  completedAtEpoch Int?
  groomerKennelId  String?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  dog          Dog     @relation(fields: [dogId], references: [id])
  ownerKennel  Kennel  @relation("GroomingListingOwnerKennel", fields: [ownerKennelId], references: [id])
  groomerKennel Kennel? @relation("GroomingListingGroomerKennel", fields: [groomerKennelId], references: [id])
  serviceActions GroomingServiceAction[]

  @@index([status])
  @@index([dogId])
  @@index([ownerKennelId])
  @@index([groomerKennelId])
}

model GroomingServiceAction {
  id              String                    @id @default(cuid())
  dogId           String
  ownerKennelId   String
  groomerKennelId String
  listingId       String?
  actionType      GroomingServiceActionType
  amountPaid      Int
  coatGain        Float
  occurredAtEpoch Int
  createdAt       DateTime                  @default(now())

  dog           Dog              @relation(fields: [dogId], references: [id])
  ownerKennel   Kennel           @relation("GroomingActionOwnerKennel", fields: [ownerKennelId], references: [id])
  groomerKennel Kennel           @relation("GroomingActionGroomerKennel", fields: [groomerKennelId], references: [id])
  listing       GroomingListing? @relation(fields: [listingId], references: [id])

  @@index([dogId])
  @@index([ownerKennelId])
  @@index([groomerKennelId])
  @@index([occurredAtEpoch])
  @@index([actionType])
}

model DogConditionEvent {
  id                  String                @id @default(cuid())
  dogId               String
  actorKennelId       String?
  ownerKennelIdAtEvent String?
  eventType           DogConditionEventType
  amount              Float
  conditionBefore     Float
  conditionAfter      Float
  groomingWeek        Int
  occurredAtEpoch     Int
  decayKey            String?               @unique
  note                String?
  createdAt           DateTime              @default(now())

  dog                 Dog     @relation(fields: [dogId], references: [id])
  actorKennel         Kennel? @relation("DogConditionEventActorKennel", fields: [actorKennelId], references: [id])
  ownerKennelAtEvent  Kennel? @relation("DogConditionEventOwnerKennel", fields: [ownerKennelIdAtEvent], references: [id])

  @@index([dogId])
  @@index([actorKennelId])
  @@index([ownerKennelIdAtEvent])
  @@index([eventType])
  @@index([groomingWeek])
}

model KennelServiceProfile {
  id                             String   @id @default(cuid())
  kennelId                       String   @unique
  groomingXp                     Int      @default(0)
  groomingLevel                  Int      @default(0)
  groomingActionsCompleted       Int      @default(0)
  outsideGroomingJobsCompleted   Int      @default(0)
  selfGroomingActionsCompleted   Int      @default(0)
  createdAt                      DateTime @default(now())
  updatedAt                      DateTime @updatedAt

  kennel Kennel @relation(fields: [kennelId], references: [id])
}

model DogListing {
  id                String           @id @default(cuid())
  dogId             String
  sellerKennelId    String?
  sellerType        SellerType
  askingPrice       Int
  listingType       String
  status            DogListingStatus @default(ACTIVE)
  listedAtEpoch     Int
  expiresAtEpoch    Int?
  soldAtEpoch       Int?
  buyerKennelId     String?
  descriptionPublic String?
  requiresBrucellosisNegativeDam Boolean @default(false)
  requiresDamHealthTestsCompleted Boolean @default(false)
  requiresDamHealthAllGreen Boolean @default(false)
  requiresDamHealthGreenOrYellow Boolean @default(false)
  requiresDamChampionTitle Boolean @default(false)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  dog          Dog     @relation(fields: [dogId], references: [id])
  sellerKennel Kennel? @relation("SellerKennelListings", fields: [sellerKennelId], references: [id])
  buyerKennel  Kennel? @relation("BuyerKennelListings", fields: [buyerKennelId], references: [id])

  @@index([dogId])
  @@index([sellerKennelId])
  @@index([buyerKennelId])
  @@index([status])
  @@index([sellerType])
}

model DogInfectiousDiseaseStatus {
  id                      String   @id @default(cuid())
  dogId                   String
  diseaseCode             String
  status                  String
  infectedAtEpoch         Int?
  sourceDogId             String?
  sourceBreedingAttemptId String?
  notes                   String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  dog       Dog  @relation("DogDiseaseStatuses", fields: [dogId], references: [id])
  sourceDog Dog? @relation("DogDiseaseSource", fields: [sourceDogId], references: [id])

  @@unique([dogId, diseaseCode])
  @@index([dogId])
  @@index([diseaseCode])
  @@index([status])
  @@index([sourceDogId])
}

model InfectiousDiseaseTestRecord {
  id                String   @id @default(cuid())
  dogId             String
  diseaseCode       String
  resultCode        String
  testedAtEpoch     Int
  validUntilEpoch   Int?
  breedingAttemptId String?
  notes             String?
  createdAt         DateTime @default(now())

  dog              Dog               @relation(fields: [dogId], references: [id])
  breedingAttempt  BreedingAttempt?  @relation(fields: [breedingAttemptId], references: [id])

  @@index([dogId, diseaseCode, testedAtEpoch])
  @@index([dogId, diseaseCode, validUntilEpoch])
  @@index([diseaseCode])
  @@index([resultCode])
  @@index([breedingAttemptId])
}

model BulletinCategory {
  id          String   @id
  slug        String   @unique
  name        String
  description String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  threads BulletinThread[]

  @@index([sortOrder])
  @@index([isActive])
}

model BulletinThread {
  id                String               @id @default(cuid())
  categoryId        String
  kennelId          String
  title             String
  sourceType        BulletinThreadSource @default(PLAYER)
  status            BulletinThreadStatus @default(OPEN)
  pinned            Boolean              @default(false)
  createdAtEpoch    Int
  lastActivityEpoch Int
  linkedDogId       String?
  linkedShowId      String?
  linkedLitterId    String?
  linkedResultId    String?
  linkedListingId   String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  category BulletinCategory @relation(fields: [categoryId], references: [id])
  kennel   Kennel           @relation(fields: [kennelId], references: [id])
  posts    BulletinPost[]

  @@index([categoryId])
  @@index([kennelId])
  @@index([sourceType])
  @@index([status])
  @@index([pinned])
  @@index([lastActivityEpoch])
  @@index([linkedDogId])
  @@index([linkedShowId])
  @@index([linkedLitterId])
}

model BulletinPost {
  id             String               @id @default(cuid())
  threadId       String
  kennelId       String
  body           String
  sourceType     BulletinThreadSource @default(PLAYER)
  hidden         Boolean              @default(false)
  createdAtEpoch Int
  editedAtEpoch  Int?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  thread BulletinThread @relation(fields: [threadId], references: [id])
  kennel Kennel         @relation(fields: [kennelId], references: [id])

  @@index([threadId])
  @@index([kennelId])
  @@index([sourceType])
  @@index([hidden])
  @@index([createdAtEpoch])
}

model KennelNotice {
  id              String           @id @default(cuid())
  kennelId        String
  type            KennelNoticeType
  title           String
  body            String?
  createdAtEpoch  Int
  readAtEpoch     Int?
  dismissedAtEpoch Int?
  linkedDogId     String?
  linkedLitterId  String?
  linkedShowId    String?
  linkedThreadId  String?
  linkedListingId String?
  metadataJson    Json?
  createdAt       DateTime         @default(now())

  kennel Kennel @relation(fields: [kennelId], references: [id])

  @@index([kennelId])
  @@index([type])
  @@index([createdAtEpoch])
  @@index([readAtEpoch])
  @@index([dismissedAtEpoch])
  @@index([linkedDogId])
  @@index([linkedLitterId])
  @@index([linkedShowId])
  @@index([linkedThreadId])
  @@index([linkedListingId])
}

model DogTitleProgress {
  dogId              String   @id
  championshipPoints Int      @default(0)
  majorCount         Int      @default(0)
  grandPoints        Int      @default(0)
  winsByTypeJson     Json?
  currentTitleCode   String?
  updatedAt          DateTime @updatedAt

  dog Dog @relation(fields: [dogId], references: [id])
}

model HealthTestRecord {
  id              String   @id @default(cuid())
  dogId           String
  testTypeCode    String
  resultCode      String
  testedAtEpoch   Int?
  revealedAtEpoch Int?
  createdAt       DateTime @default(now())
  isPublic        Boolean  @default(true)
  notes           String?
  detailsJson     Json?

  dog Dog @relation(fields: [dogId], references: [id])

  @@index([dogId, testTypeCode, testedAtEpoch])
  @@index([testTypeCode])
  @@index([resultCode])
}

model DogHealthConditionTruth {
  id                  String   @id @default(cuid())
  dogId               String
  conditionCode       String
  geneticLiability    Float
  environmentModifier Float    @default(0)
  alleleA             String?
  alleleB             String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  dog Dog @relation(fields: [dogId], references: [id])

  @@unique([dogId, conditionCode])
  @@index([conditionCode])
}
