// STEP 1 PATCH ONLY
// Apply these changes to your existing schema before wiring auth + kennel bootstrap.

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  displayName  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  kennels Kennel[]
}

model Kennel {
  id              String   @id @default(cuid())
  userId          String?
  name            String   @unique
  slug            String   @unique
  isNpc           Boolean  @default(false)
  homeDistrictId  String?
  balance         Int      @default(0)
  reputationScore Int      @default(0)
  publicSlogan    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([homeDistrictId])
}
